# Connection target for smig commands. Pick one of the two test databases
# brought up by `just build-db-shell` or `just build-db-smig`, or override
# to point at a remote env.

# smig-managed test db on port 5434
PGHOST=localhost
PGPORT=5434
PGUSER=bookable
PGPASSWORD=bookable
PGDATABASE=bookable
PGSSLMODE=disable

# Path defaults match the smig-managed fixture tree. Swap database/smig to
# database/shell to target the shell-managed image on port 5433 instead.
MIGRATE_SCHEMA=./database/smig/migrate.yml
DB_DIR=./database/smig

# Required for `smig down`. Leave empty to disable AI synthesis.
ANTHROPIC_API_KEY=

# Default model for the down agent. Override per invocation with --model.
ANTHROPIC_MODEL=claude-sonnet-4-6
